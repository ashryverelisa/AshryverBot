@using AshryverBot.Database.Entities

<MudDialog>
    <DialogContent>
        <MudForm @ref="_form" Model="_model">
            <MudTextField T="string"
                          @bind-Value="_model.Name"
                          Label="Name"
                          Required="true"
                          RequiredError="Name is required."
                          MaxLength="64"
                          Adornment="Adornment.Start"
                          AdornmentText="!"
                          HelperText="Used as !name in chat."
                          Immediate="true" />
            <MudTextField T="string"
                          @bind-Value="_model.Response"
                          Label="Response"
                          Required="true"
                          RequiredError="Response is required."
                          MaxLength="500"
                          Lines="3"
                          Class="mt-3" />
            <MudNumericField T="int"
                             @bind-Value="_model.CooldownSeconds"
                             Label="Cooldown (seconds)"
                             Min="0"
                             Max="3600"
                             Class="mt-3" />
            <MudSelect T="CommandRole"
                       @bind-Value="_model.RequiredRole"
                       Label="Required role"
                       Class="mt-3">
                @foreach (var role in Enum.GetValues<CommandRole>())
                {
                    <MudSelectItem Value="role">@role</MudSelectItem>
                }
            </MudSelect>
            <MudSwitch T="bool"
                       @bind-Value="_model.IsEnabled"
                       Color="Color.Primary"
                       Label="Enabled"
                       Class="mt-3" />
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@Cancel">Cancel</MudButton>
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   OnClick="@Submit"
                   Disabled="_saving">
            @(IsNew ? "Create" : "Save")
        </MudButton>
    </DialogActions>
</MudDialog>