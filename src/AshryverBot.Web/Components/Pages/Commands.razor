@page "/commands"

<PageTitle>Commands · AshryverBot</PageTitle>

<MudStack Spacing="4">
    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
        <div>
            <MudText Typo="Typo.h4">Commands</MudText>
            <MudText Typo="Typo.subtitle1" Class="mud-text-secondary">
                Manage your chat commands.
            </MudText>
        </div>
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Add"
                   OnClick="@OpenAddDialog">
            New command
        </MudButton>
    </MudStack>

    <MudPaper Elevation="2">
        <MudToolBar Dense="true">
            <MudTextField T="string"
                          @bind-Value="_search"
                          Placeholder="Search commands..."
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search"
                          Variant="Variant.Text"
                          Margin="Margin.Dense"
                          Immediate="true" />
            <MudSpacer />
            <MudText Typo="Typo.caption" Class="mud-text-secondary">
                @FilteredCommands.Count() of @_commands.Count
            </MudText>
        </MudToolBar>
        <MudDivider />
        <MudTable Items="FilteredCommands"
                  Hover="true"
                  Breakpoint="Breakpoint.Sm"
                  Dense="false"
                  Loading="_loading"
                  LoadingProgressColor="Color.Primary">
            <HeaderContent>
                <MudTh Style="width: 80px;">Active</MudTh>
                <MudTh>Command</MudTh>
                <MudTh>Response</MudTh>
                <MudTh Style="width: 110px;">Cooldown</MudTh>
                <MudTh Style="width: 140px;">Permission</MudTh>
                <MudTh Style="width: 110px;"></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>
                    <MudSwitch T="bool"
                               Value="context.IsEnabled"
                               ValueChanged="@(v => OnToggleEnabled(context, v))"
                               Color="Color.Primary" />
                </MudTd>
                <MudTd>
                    <MudText Typo="Typo.body2" Style="font-family: monospace;">!@context.Name</MudText>
                </MudTd>
                <MudTd>
                    <MudText Typo="Typo.body2" Class="mud-text-secondary">@context.Response</MudText>
                </MudTd>
                <MudTd>@context.CooldownSeconds s</MudTd>
                <MudTd>
                    <MudChip T="string" Size="Size.Small" Color="@PermissionColor(context.RequiredRole)" Variant="Variant.Filled">
                        @context.RequiredRole
                    </MudChip>
                </MudTd>
                <MudTd>
                    <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                   Size="Size.Small"
                                   OnClick="@(() => OpenEditDialog(context))" />
                    <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                   Size="Size.Small"
                                   Color="Color.Error"
                                   OnClick="@(() => Delete(context))" />
                </MudTd>
            </RowTemplate>
            <NoRecordsContent>
                <MudText>No commands found.</MudText>
            </NoRecordsContent>
        </MudTable>
    </MudPaper>
</MudStack>